# Environment variables — NUNCA versionar com dados reais
.env
.env.local
.env.*.local

# Logs
storage/logs/*
!storage/logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Composer — vendor/ INCLUÍDO no repositório para deploy sem SSH/Composer no Hostgator
# composer.lock incluído para garantir versões exatas
# vendor/  <-- REMOVIDO do gitignore propositalmente

# Cache
*.cache

# Uploads de usuários (não versionar arquivos enviados)
public/assets/uploads/*
!public/assets/uploads/.gitkeep
