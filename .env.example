# AppAuto SaaS — Arquivo de Configuração de Ambiente
# =====================================================
# INSTRUÇÃO: Copie este arquivo como ".env" no servidor
# e preencha com os dados reais da sua hospedagem.
# NUNCA versione o arquivo .env com dados reais!
# =====================================================

APP_NAME=AppAuto
APP_ENV=prod
APP_DEBUG=false
APP_URL=https://erp.appauto.com.br

# Banco de Dados MySQL (Hostgator)
# Crie o banco no cPanel > MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=NOME_DO_BANCO
DB_USERNAME=USUARIO_MYSQL
DB_PASSWORD=SENHA_MYSQL

# E-mail (usa mail() nativo do PHP por padrão)
MAIL_FROM=noreply@appauto.com.br
MAIL_FROM_NAME=AppAuto
